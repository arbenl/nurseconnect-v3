# =================================================
# NurseConnect V3 — Local Development Environment (NO FIREBASE)
# =================================================
# Copy to .env.local and fill in values.
# Firebase is intentionally not supported in V3.

# -------------------------------------------------
# App
# -------------------------------------------------
APP_URL="http://localhost:3010"
# Vercel provides VERCEL_URL automatically for preview deployments.
# Set APP_URL and BETTER_AUTH_URL explicitly for production custom domains.

# -------------------------------------------------
# PostgreSQL (Drizzle / packages/database)
# -------------------------------------------------
DATABASE_URL="postgresql://nurseconnect:nurseconnect@127.0.0.1:5432/nurseconnect"
DATABASE_POOL_URL=""                  # Optional: Pooled connection URL (e.g. PgBouncer / provider pooler) for app runtime.
PGPOOL_MAX=""                         # Optional (int): Max number of clients in the pool
PGPOOL_MIN=""                         # Optional (int): Minimum number of clients in the pool
PGPOOL_IDLE_TIMEOUT_MS=""             # Optional (int): Ms a client must sit idle in the pool before closing (Vercel tip: 5000)
PGPOOL_CONNECTION_TIMEOUT_MS=""       # Optional (int): Ms to wait for a connection from the pool
PGPOOL_MAX_LIFETIME_SECONDS=""        # Optional (int): Max time a connection can exist before closing
PGPOOL_ALLOW_EXIT_ON_IDLE=""          # Optional (boolean): Allow Node to exit if pool sits idle (useful for scripts)

# -------------------------------------------------
# Better-Auth (Phase 2)
# -------------------------------------------------
BETTER_AUTH_SECRET=""                 # Generate: openssl rand -base64 32
BETTER_AUTH_URL="http://localhost:3010"
FIRST_ADMIN_EMAILS=""                 # Optional: comma-separated list of emails to bootstrap to admin. Leaving empty = safe default (no admins created).

# Email verification
# Local/dev default can stay off. Production must use observe or enforce.
NC_EMAIL_VERIFICATION_MODE=off        # off | observe | enforce
EMAIL_PROVIDER=disabled               # disabled | test | postmark
EMAIL_FROM=""                         # Required email address in production observe/enforce
POSTMARK_SERVER_TOKEN=""              # Required in production observe/enforce

# -------------------------------------------------
# Model review routes
# -------------------------------------------------
# Claude CLI aliases resolve to the current installed Opus/Sonnet models.
CLAUDE_48_REVIEW_MODEL=opus
CLAUDE_47_REVIEW_MODEL=sonnet
CLAUDE_SONNET_46_REVIEW_MODEL=sonnet
# -------------------------------------------------
# Feature Flags — Backend Source of Truth (DEFAULT POSTGRES)
# -------------------------------------------------
FEATURE_BACKEND_NURSE_PROFILE=postgres
FEATURE_BACKEND_PATIENT_PROFILE=postgres
FEATURE_BACKEND_SERVICE_REQUEST=postgres
FEATURE_BACKEND_ASSIGNMENT=postgres
FEATURE_BACKEND_VISIT=postgres
