{
  "extends": ["next/core-web-vitals"],
  "rules": {
    "no-restricted-imports": [
      "error",
      {
        "patterns": [
          {
            "group": ["firebase/*", "firebase-admin/*", "@firebase/*"],
            "message": "Firebase is not supported in NurseConnect V3. Use Better Auth and @nurseconnect/database."
          },
          {
            "group": ["@/lib/firebase*", "@/lib/firebaseClient*"],
            "message": "Firebase is not supported in NurseConnect V3. Use Better Auth and @nurseconnect/database."
          }
        ]
      }
    ]
  },
  "settings": {
    "import/resolver": {
      "typescript": {
        "project": "./tsconfig.json"
      }
    }
  }
}
