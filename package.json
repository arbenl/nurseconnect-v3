{
  "name": "nurseconnect-v3",
  "private": true,
  "packageManager": "pnpm@10.15.0+sha512.486ebc259d3e999a4e8691ce03b5cac4a71cbeca39372a9b762cb500cfdf0873e2cb16abe3d951b1ee2cf012503f027b98b6584e4df22524e0c7450d9ec7aa7b",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "type-check": "turbo run type-check",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "dev": "turbo run dev --parallel",
    "agents:plan": "node scripts/agent-runner.mjs",
    "agents:plan:all": "TASK=$TASK node scripts/agent-runner.mjs dev $TASK && node scripts/agent-runner.mjs qa $TASK && node scripts/agent-runner.mjs security $TASK && node scripts/agent-runner.mjs ops $TASK",
    "steer:run": "node scripts/steer-run.mjs",
    "steer:verify": "node scripts/steer-verify.mjs",
    "steer:orchestrate": "node scripts/steer-run-and-verify.mjs",
    "steer:deliver": "node scripts/steer-deliver.mjs",
    "agents:orchestrate": "node scripts/steer-run.mjs",
    "agents:orchestrate:verify": "node scripts/steer-verify.mjs",
    "agents:apply": "node scripts/apply-plan.mjs",
    "agents:phase": "make full-phase TASK=$TASK",
    "multiagent:run": "node scripts/multi-agent/run.mjs",
    "multiagent:policy": "node scripts/multi-agent/policy.mjs",
    "multiagent:metrics": "node scripts/multi-agent/metrics.mjs",
    "multiagent:benchmark": "node scripts/multi-agent/benchmark.mjs",
    "multiagent:benchmark:weekly": "node scripts/multi-agent/benchmark-weekly.mjs",
    "multiagent:a2a": "node scripts/multi-agent/a2a.mjs",
    "multiagent:verify-fix": "node scripts/multi-agent/verify-fix.mjs",
    "multiagent:finalizer": "node scripts/multi-agent/finalizer.mjs",
    "slice:evidence": "node scripts/multi-agent/slice-evidence.mjs",
    "subagent-results": "node scripts/multi-agent/subagent-results.mjs",
    "multiagent:pr-hardening": "node scripts/multi-agent/run.mjs --task pr-hardening --mode multi --complexity 8 --independent-task-count 3 --requires-compliance-review true",
    "multiagent:sentinel": "bash scripts/multi-agent/sentinel-agent.sh",
    "multiagent:sonar": "bash scripts/multi-agent/sonar-agent.sh",
    "model-review": "node scripts/multi-agent/model-review.mjs",
    "codex:senior-review": "node scripts/multi-agent/codex-senior-review.mjs",
    "codex:senior-review:supabase": "node scripts/multi-agent/codex-senior-review.mjs --mode supabase",
    "repo:hygiene": "node scripts/repo-hygiene.mjs",
    "identity:current-user-boundary": "node scripts/current-user-boundary.mjs",
    "tenant:isolation": "node scripts/tenant-isolation-abuse.mjs",
    "architecture:boundaries": "node scripts/check-architecture-boundaries.mjs",
    "sentry:advisory": "node scripts/multi-agent/sentry-advisory.mjs",
    "modularity:guard": "node scripts/check-modularity-guard.mjs",
    "verify-slice": "bash scripts/multi-agent/verify-slice.sh",
    "ent:gates": "node scripts/ent-gates/check.mjs",
    "mcp:preflight": "node scripts/mcp/preflight.mjs",
    "ci:phase": "pnpm type-check && pnpm lint && pnpm test:ci",
    "ci:local": "pnpm type-check && pnpm -F web build && pnpm -w vitest run && pnpm -F web lint",
    "pr:finalizer": "bash scripts/pr-finalizer.sh",
    "test:web": "pnpm --filter web test",
    "test:contracts": "pnpm --filter contracts test",
    "test:scripts": "vitest run scripts/multi-agent/__tests__ scripts/__tests__ scripts/ent-gates/__tests__",
    "test:architecture": "pnpm architecture:boundaries && pnpm identity:current-user-boundary && pnpm --filter @nurseconnect/contracts build && pnpm --filter @nurseconnect/platform-telemetry test && pnpm --filter @nurseconnect/domain-request test && pnpm --filter @nurseconnect/domain-dispatch test && pnpm --filter @nurseconnect/domain-identity test && pnpm --filter @nurseconnect/domain-nurse test && pnpm --filter @nurseconnect/domain-admin-ops test && pnpm --filter @nurseconnect/domain-payments test && pnpm --filter @nurseconnect/domain-visit test",
    "test:ci": "pnpm test:web && pnpm test:contracts && pnpm test:scripts && pnpm test:architecture",
    "test:coverage": "node scripts/sonar-coverage.mjs",
    "test:api": "bash scripts/test-api.sh",
    "gate:fast": "pnpm -w type-check && pnpm lint && pnpm test:ci",
    "gate:smoke": "pnpm -w type-check && pnpm lint && pnpm test:ci && pnpm test:api",
    "gate:e2e-api": "bash scripts/gate-e2e-api.sh",
    "gate:e2e": "pnpm gate:e2e-api",
    "db:generate": "drizzle-kit generate --config packages/database/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config packages/database/drizzle.config.ts",
    "db:reset:schema": "bash scripts/db-reset-schema.sh",
    "db:from-clean": "bash scripts/db-from-clean.sh",
    "db:push": "drizzle-kit push --config packages/database/drizzle.config.ts",
    "db:check": "pnpm --filter @nurseconnect/database db:check",
    "db:verify-meta": "pnpm --filter @nurseconnect/database db:verify-meta",
    "gate:release": "pnpm -w type-check && pnpm lint && pnpm --filter web build && pnpm test:ci && pnpm test:api && pnpm gate:e2e-api && cross-env CI=1 pnpm --filter web test:e2e:ui-smoke",
    "launch:readiness": "node scripts/launch-readiness-report.mjs",
    "launch:readiness:json": "node scripts/launch-readiness-report.mjs --json",
    "launch:seed": "node scripts/launch-rehearsal-seed.mjs",
    "launch:rehearsal": "bash scripts/launch-rehearsal.sh",
    "launch:browser-rehearsal": "bash scripts/launch-browser-rehearsal.sh",
    "launch:browser-rehearsal:headed": "bash scripts/launch-browser-rehearsal-headed.sh",
    "launch:monitor": "node scripts/launch-monitor.mjs",
    "launch:auth-monitor": "node scripts/launch-auth-monitor.mjs",
    "branch-protection:audit": "node scripts/check-branch-protection.mjs",
    "auth:email-verification-report": "node scripts/auth-email-verification.mjs report",
    "auth:email-verification-backfill": "node scripts/auth-email-verification.mjs apply",
    "identity:reconcile": "node scripts/identity/reconcile-auth-bridge.mjs",
    "sonar:start": "docker compose --profile sonar up -d sonarqube sonar-db",
    "sonar:stop": "docker compose --profile sonar stop sonarqube sonar-db",
    "sonar:down": "docker compose --profile sonar down --remove-orphans",
    "sonar:reset": "docker compose --profile sonar down -v --remove-orphans",
    "sonar:logs": "docker compose logs -f sonarqube",
    "sonar:scan": "node scripts/sonar-scan.mjs",
    "sonar:gate": "bash scripts/sonar-gate.sh",
    "sonar:full": "pnpm type-check && pnpm test:coverage && pnpm sonar:scan",
    "guard:strict": "bash scripts/strict-workflow-guard.sh pre-push",
    "guard:pr-comments": "node scripts/check-pr-bot-comments.mjs",
    "hooks:install": "bash scripts/install-git-hooks.sh",
    "env:check": "node scripts/env-check.mjs"
  },
  "devDependencies": {
    "@google/gemini-cli": "0.28.2",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.4.6",
    "@types/node": "^20.12.12",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.30.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-turbo": "^2.8.9",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "node-fetch": "^3.3.2",
    "turbo": "^2.0.6",
    "typescript": "^5.4.5",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.0.17"
  },
  "pnpm": {
    "overrides": {
      "zod": "^4.0.17",
      "@types/react": "^19.0.0",
      "@types/react-dom": "^19.0.0",
      "caniuse-lite": "^1.0.30001788"
    }
  }
}
